<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>KoreanLevels – Formality Translator</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:#080812;color:#f0f0f0;min-height:100vh;overflow-x:hidden}
  .bg-grad{position:fixed;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(233,69,96,.08) 0%,transparent 60%),radial-gradient(ellipse at 80% 80%,rgba(83,52,131,.08) 0%,transparent 60%);pointer-events:none}
  .bg-dots{position:fixed;inset:0;background-image:radial-gradient(rgba(255,255,255,.03) 1px,transparent 1px);background-size:30px 30px;pointer-events:none}
  header{border-bottom:1px solid rgba(255,255,255,.06);background:rgba(8,8,18,.85);backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;padding:0 24px}
  .header-inner{max-width:900px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:64px}
  .logo{display:flex;align-items:center;gap:12px}
  .logo-ko{font-family:'Noto Serif KR',serif;font-size:32px;font-weight:700;color:#e94560;line-height:1}
  .logo-title{font-size:16px;font-weight:700;color:#fff;letter-spacing:-.3px}
  .logo-sub{font-size:11px;color:#666;letter-spacing:.5px;text-transform:uppercase}
  .header-tag{font-size:11px;font-weight:600;color:#e94560;border:1px solid rgba(233,69,96,.3);border-radius:20px;padding:4px 12px;text-transform:uppercase;letter-spacing:.5px}
  .hero{max-width:900px;margin:0 auto;padding:60px 24px 40px;text-align:center;position:relative;z-index:1}
  .eyebrow{font-size:12px;font-weight:600;color:#e94560;text-transform:uppercase;letter-spacing:2px;margin-bottom:16px}
  h1{font-size:clamp(36px,6vw,64px);font-weight:700;line-height:1.1;color:#fff;margin-bottom:16px;letter-spacing:-1px}
  .accent{color:#e94560;font-family:'Noto Serif KR',serif}
  .hero-desc{font-size:16px;color:#999;max-width:500px;margin:0 auto 40px;line-height:1.6}
  .input-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:24px;max-width:700px;margin:0 auto;text-align:left}
  .input-label{font-size:12px;font-weight:600;color:#666;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px}
  .input-row{display:flex;gap:12px;align-items:flex-start}
  textarea{flex:1;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:12px 16px;color:#fff;font-size:15px;line-height:1.5;resize:none;font-family:'DM Sans',sans-serif;transition:border-color .2s}
  textarea:focus{outline:none;border-color:#e94560}
  textarea::placeholder{color:#555}
  #translate-btn{background:#e94560;color:#fff;border:none;border-radius:10px;padding:12px 22px;font-size:14px;font-weight:600;cursor:pointer;white-space:nowrap;font-family:'DM Sans',sans-serif;min-width:120px;transition:opacity .2s}
  #translate-btn:disabled{opacity:.4;cursor:not-allowed}
  .examples-row{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:14px}
  .examples-label{font-size:12px;color:#555;font-weight:600}
  .chip{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:4px 12px;font-size:12px;color:#aaa;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
  .chip:hover{background:rgba(255,255,255,.1);color:#fff}
  #loading{display:none;text-align:center;padding:40px 24px;position:relative;z-index:1}
  .dots{display:flex;gap:8px;justify-content:center;margin-bottom:12px}
  .dot{width:10px;height:10px;border-radius:50%;background:#e94560;display:inline-block;animation:bounce 1.4s ease-in-out infinite}
  .loading-text{color:#666;font-size:14px}
  @keyframes bounce{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}
  #error{display:none;max-width:700px;margin:16px auto;padding:12px 20px;background:rgba(233,69,96,.1);border:1px solid rgba(233,69,96,.3);border-radius:10px;color:#e94560;font-size:14px;text-align:center;position:relative;z-index:1}
  #results{display:none;max-width:900px;margin:0 auto;padding:0 24px 60px;position:relative;z-index:1}
  .results-header{text-align:center;margin-bottom:32px}
  .results-title{font-size:13px;font-weight:600;color:#e94560;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px}
  .results-original{font-size:20px;font-weight:600;color:#fff;font-style:italic}
  .cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px}
  .card{border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,.08);background:#0e0e1c;animation:fadeUp .4s ease both}
  @keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
  .card-header{padding:20px 20px 16px}
  .card-header-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
  .card-icon{font-size:24px}
  .card-badge{font-size:11px;font-weight:700;color:#fff;border-radius:20px;padding:3px 10px;font-family:'Noto Serif KR',serif}
  .card-level{font-size:22px;font-weight:700;color:#fff;letter-spacing:-.5px}
  .card-level-ko{font-size:13px;color:rgba(255,255,255,.5);font-family:'Noto Serif KR',serif;margin-top:2px}
  .card-body{padding:20px}
  .sec{margin-bottom:16px}
  .sec-label{font-size:10px;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
  .korean-text{font-family:'Noto Serif KR',serif;font-size:22px;color:#fff;font-weight:700;line-height:1.4;margin-bottom:6px}
  .roman-text{font-size:14px;color:#e94560;font-style:italic;letter-spacing:.3px;line-height:1.5}
  .copy-btn{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:6px;padding:3px 10px;font-size:11px;color:#aaa;cursor:pointer;font-family:'DM Sans',sans-serif}
  .copy-btn:hover{color:#fff}
  .usage-box{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:8px;padding:10px 12px;display:flex;gap:8px;align-items:flex-start}
  .usage-text{font-size:12px;color:#888;line-height:1.5}
  #how{max-width:700px;margin:0 auto;padding:20px 24px 80px;position:relative;z-index:1;text-align:center}
  .how-title{font-size:13px;font-weight:600;color:#555;text-transform:uppercase;letter-spacing:2px;margin-bottom:24px}
  .how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .how-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:20px 16px}
  .how-step{width:32px;height:32px;border-radius:50%;background:rgba(233,69,96,.15);border:1px solid rgba(233,69,96,.3);color:#e94560;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 10px}
  .how-text{font-size:13px;color:#777;line-height:1.5}
  ::-webkit-scrollbar{width:6px}
  ::-webkit-scrollbar-track{background:#0a0a14}
  ::-webkit-scrollbar-thumb{background:#333;border-radius:3px}
</style>
</head>
<body>
<div class="bg-grad"></div>
<div class="bg-dots"></div>

<header>
  <div class="header-inner">
    <div class="logo">
      <span class="logo-ko">한</span>
      <div>
        <div class="logo-title">KoreanLevels</div>
        <div class="logo-sub">Formality Translator</div>
      </div>
    </div>
    <div class="header-tag">AI Powered</div>
  </div>
</header>

<section class="hero">
  <div class="eyebrow">English → Korean</div>
  <h1>Speak Korean<br><span class="accent">at Every Level</span></h1>
  <p class="hero-desc">Translate any English sentence into 3 Korean formality levels — with pronunciation guide included.</p>
  <div class="input-card">
    <div class="input-label">Enter English Sentence</div>
    <div class="input-row">
      <textarea id="user-input" placeholder="Type any sentence in English..." rows="2"></textarea>
      <button id="translate-btn" onclick="doTranslate()">Translate →</button>
    </div>
    <div class="examples-row">
      <span class="examples-label">Try:</span>
      <button class="chip" onclick="useExample(this)">Where is the bathroom?</button>
      <button class="chip" onclick="useExample(this)">I would like to order food.</button>
      <button class="chip" onclick="useExample(this)">Can you help me?</button>
      <button class="chip" onclick="useExample(this)">Thank you very much.</button>
      <button class="chip" onclick="useExample(this)">I don't understand.</button>
    </div>
  </div>
</section>

<div id="error"></div>

<div id="loading">
  <div class="dots">
    <span class="dot" style="animation-delay:0s"></span>
    <span class="dot" style="animation-delay:.2s"></span>
    <span class="dot" style="animation-delay:.4s"></span>
  </div>
  <div class="loading-text">Translating into 3 levels...</div>
</div>

<section id="results">
  <div class="results-header">
    <div class="results-title">Translation Results</div>
    <div class="results-original" id="results-original"></div>
  </div>
  <div class="cards-grid" id="cards-grid"></div>
</section>

<section id="how">
  <div class="how-title">How It Works</div>
  <div class="how-grid">
    <div class="how-card"><div class="how-step">1</div><div class="how-text">Type any English sentence above</div></div>
    <div class="how-card"><div class="how-step">2</div><div class="how-text">AI translates into 3 formality levels</div></div>
    <div class="how-card"><div class="how-step">3</div><div class="how-text">Get Korean text + pronunciation guide</div></div>
  </div>
</section>

<script>
const API_KEY = "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";

const LEVELS = [
  { key:"very_formal", label:"Very Formal", korean:"격식체", icon:"👔", headerBg:"#1a1a2e", badgeBg:"#e94560", badge:"합쇼체" },
  { key:"formal",      label:"Formal",      korean:"존댓말", icon:"🤝", headerBg:"#16213e", badgeBg:"#0f3460", badge:"해요체" },
  { key:"casual",      label:"Casual",      korean:"반말",   icon:"😊", headerBg:"#0f3460", badgeBg:"#533483", badge:"반말"  },
];

const PROMPT = `You are a Korean language expert. Translate the given English sentence into THREE formality levels in Korean.

Respond ONLY in this exact JSON format, no extra text, no markdown backticks:
{"very_formal":{"korean":"...","romanization":"...","usage":"..."},"formal":{"korean":"...","romanization":"...","usage":"..."},"casual":{"korean":"...","romanization":"...","usage":"..."}}

Where:
- korean = Korean text in Hangul
- romanization = English pronunciation (Revised Romanization)
- usage = 1 sentence explaining when to use this level`;

function useExample(el){
  document.getElementById('user-input').value = el.textContent;
  doTranslate();
}

async function doTranslate(){
  const input = document.getElementById('user-input').value.trim();
  if(!input) return;

  const btn = document.getElementById('translate-btn');
  const loading = document.getElementById('loading');
  const error = document.getElementById('error');
  const results = document.getElementById('results');
  const how = document.getElementById('how');

  btn.disabled = true;
  btn.textContent = '...';
  loading.style.display = 'block';
  error.style.display = 'none';
  results.style.display = 'none';
  how.style.display = 'none';

  try {
    const res = await fetch(
      `https://api.groq.com/openai/v1/chat/completions`,
      {
        method: 'POST',
        headers: {'Content-Type':'application/json', 'Authorization': 'Bearer ' + API_KEY},
        body: JSON.stringify({
          model: 'llama-3.3-70b-versatile',
          messages: [
            { role: 'system', content: PROMPT },
            { role: 'user', content: 'English sentence: ' + input }
          ],
          temperature: 0.3,
          max_tokens: 1000
        })
      }
    );

    const data = await res.json();

    if(!res.ok){
      throw new Error(data.error?.message || 'API Error');
    }

    const raw = data.choices?.[0]?.message?.content || '';
    const clean = raw.replace(/```json|```/g,'').trim();
    const parsed = JSON.parse(clean);

    document.getElementById('results-original').textContent = '"' + input + '"';
    const grid = document.getElementById('cards-grid');
    grid.innerHTML = '';

    LEVELS.forEach((lvl, i) => {
      const d = parsed[lvl.key];
      if(!d) return;
      const card = document.createElement('div');
      card.className = 'card';
      card.style.animationDelay = (i * 0.1) + 's';
      card.innerHTML = `
        <div class="card-header" style="background:${lvl.headerBg}">
          <div class="card-header-top">
            <span class="card-icon">${lvl.icon}</span>
            <span class="card-badge" style="background:${lvl.badgeBg}">${lvl.badge}</span>
          </div>
          <div class="card-level">${lvl.label}</div>
          <div class="card-level-ko">${lvl.korean}</div>
        </div>
        <div class="card-body">
          <div class="sec">
            <div class="sec-label">Korean</div>
            <div class="korean-text">${d.korean}</div>
            <button class="copy-btn" onclick="copyText(this, \`${d.korean}\`)">Copy</button>
          </div>
          <div class="sec">
            <div class="sec-label">🔊 Pronunciation</div>
            <div class="roman-text">${d.romanization}</div>
          </div>
          <div class="usage-box">
            <span>💡</span>
            <span class="usage-text">${d.usage}</span>
          </div>
        </div>`;
      grid.appendChild(card);
    });

    results.style.display = 'block';
  } catch(e) {
    error.textContent = 'Translation failed: ' + e.message + '. Please try again.';
    error.style.display = 'block';
    how.style.display = 'block';
  } finally {
    loading.style.display = 'none';
    btn.disabled = false;
    btn.textContent = 'Translate →';
  }
}

function copyText(btn, text){
  navigator.clipboard.writeText(text).then(()=>{
    btn.textContent = '✓ Copied';
    setTimeout(()=> btn.textContent = 'Copy', 2000);
  });
}

document.getElementById('user-input').addEventListener('keydown', e => {
  if(e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); doTranslate(); }
});
</script>
</body>
</html>
